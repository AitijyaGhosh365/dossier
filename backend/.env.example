# Anthropic API key — get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Model. Recommended:
#   claude-sonnet-4-6   — best balance of quality, latency, and cost.
#   claude-opus-4-7     — highest quality for nuanced evaluations.
#   claude-haiku-4-5    — fastest, cheapest. Good for iteration.
ANTHROPIC_MODEL=claude-sonnet-4-6

# CORS — origin of the Next.js dev server. (The backend also accepts any LAN IP.)
FRONTEND_ORIGIN=http://localhost:3000
